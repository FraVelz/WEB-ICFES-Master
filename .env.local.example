# Firebase Configuration
# Obtén estos valores de tu proyecto en: https://console.firebase.google.com
# 1. Ve a Project Settings (Engranaje en la esquina superior izquierda)
# 2. En la sección "General", desplázate hacia abajo y encontrarás la configuración

VITE_FIREBASE_API_KEY=tu_api_key_aqui
VITE_FIREBASE_AUTH_DOMAIN=tu_proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu_project_id
VITE_FIREBASE_STORAGE_BUCKET=tu_proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=tu_messaging_sender_id
VITE_FIREBASE_APP_ID=tu_app_id
VITE_FIREBASE_MEASUREMENT_ID=tu_measurement_id
