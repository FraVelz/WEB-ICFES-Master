# Copia este archivo a .env.local y rellena los valores.
# URL pública del sitio (SEO: metadataBase, sitemap, Open Graph).
# En Vercel sin esta variable se usa VERCEL_URL (p. ej. https://tu-proyecto.vercel.app).
# Producción: https://icfes-master.vercel.app
# En Vercel puedes fijar la URL canónica explícita (recomendado en producción):
# NEXT_PUBLIC_SITE_URL=https://icfes-master.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Recomendado en producción — twitter:site en metadatos (sin @ también vale)
NEXT_PUBLIC_TWITTER_SITE=@icfesmaster

# Supabase (obligatorio para login real en el cliente)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key

# Solo servidor: scripts locales, perfil público y firma HMAC de exámenes por bloque
# (si no defines BLOCK_EXAM_SESSION_SECRET, se reutiliza esta clave).
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# Tras OAuth (Google), en Supabase Dashboard → Authentication → URL Configuration:
# Site URL: http://localhost:3000 (o tu dominio)
# Redirect URLs (ejemplos):
#   http://localhost:3000/auth/callback
#   http://localhost:3000/auth/callback?next=/ruta-aprendizaje
#   http://localhost:3000/reset-password
#   https://tu-dominio.com/auth/callback

# Rate limiting distribuido (recomendado en producción Vercel — sin esto los límites son in-memory por instancia)
# Afecta chat (cuota diaria + burst), perfil público, gamificación y APIs de examen.
# KV_REST_API_URL=https://xxx.upstash.io
# KV_REST_API_TOKEN=tu_token

# Opcional — firma HMAC dedicada para exámenes por bloque.
# Si no se define, en servidor se reutiliza SUPABASE_SERVICE_ROLE_KEY (ya obligatoria en Vercel).
# BLOCK_EXAM_SESSION_SECRET=genera_un_secreto_largo_aleatorio

# Feature flags — defaults are safe/off (see docs/es/decisions/billing-no-2026.md)
# Billing / Free-Pro-Premium product: keep false for 2026
BILLING_ENABLED=false
NEXT_PUBLIC_BILLING_ENABLED=false

# OpenAI chat assistant: requires flag + key. Off if either is missing.
OPENAI_ENABLED=false
NEXT_PUBLIC_OPENAI_ENABLED=false
OPENAI_API_KEY=sk-...

# Cloudflare R2 — infografías en /consejos
# Sube PDFs a icfes-recursos/acerca-de-icfes-11-pdfs/ (nombres como en materiales-icfes/)

# Opción A — URL pública (recomendado en producción con dominio custom)
# NEXT_PUBLIC_R2_PUBLIC_URL=https://recursos.tudominio.com
# NEXT_PUBLIC_R2_PDF_PREFIX=acerca-de-icfes-11-pdfs

# Opción B — servidor Next lee R2 con API S3 (bucket privado o sin URL pública)
# NUNCA pongas R2_SECRET_* ni ACCESS_KEY en variables NEXT_PUBLIC_*
NEXT_PUBLIC_R2_USE_API=true
R2_ENDPOINT=https://TU_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=tu_access_key_id
R2_SECRET_ACCESS_KEY=tu_secret_access_key
R2_BUCKET_NAME=icfes-recursos
R2_PDF_PREFIX=acerca-de-icfes-11-pdfs
