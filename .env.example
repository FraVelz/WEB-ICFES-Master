# ============================================
# VARIABLES DE ENTORNO - ICFES Master
# ============================================
# 
# INSTRUCCIONES:
# 1. Copia este archivo a .env: cp .env.example .env
# 2. Completa los valores con tus credenciales reales
# 3. NUNCA subas el archivo .env al repositorio
#
# ============================================

# Firebase Client SDK (Frontend)
# Obtén estos valores desde: Firebase Console > Project Settings > General > Your apps
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id  # Opcional

# Firebase Admin SDK (Backend/Scripts)
# Ruta al archivo JSON de credenciales de Firebase Admin SDK
# Descarga el archivo desde: Firebase Console > Project Settings > Service Accounts > Generate new private key
# IMPORTANTE: Coloca el archivo fuera del repositorio (ej: ~/.config/icfes/firebase-adminsdk.json)
FIREBASE_ADMIN_SDK_CREDENTIALS_PATH=./credentials/firebase-adminsdk.json

# API Configuration (Opcional)
VITE_API_MODE=localStorage
VITE_API_URL=http://localhost:3001/api
VITE_API_TOKEN=

# Email Configuration (Para Firebase Functions)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
